config BR2_PACKAGE_OPENVINO_BENCHMARK
	bool "openvino-benchmark"
	depends on BR2_x86_64
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_INSTALL_LIBSTDCPP
	select BR2_PACKAGE_OPENVINO_RUNTIME
	help
	  Inference benchmark tool for the OpenVINO 2024 C++ API.

	  Measures throughput (FPS) and latency statistics
	  (avg/min/max/p50/p90/p99) for any OpenVINO-compatible model
	  (.xml IR or .onnx) on the specified device.

	  Installs:
	    /usr/bin/benchmark_app

	  Usage:
	    benchmark_app -m <model.xml> [-d CPU|GPU|NPU|AUTO] \
	                  [-niter 1000] [-nwarmup 5] [-nireq 1] [-async]

	  https://github.com/openvinotoolkit/openvino

comment "openvino-benchmark requires a glibc toolchain, x86_64, and C++ support"
	depends on !BR2_x86_64 || !BR2_TOOLCHAIN_USES_GLIBC || !BR2_INSTALL_LIBSTDCPP
