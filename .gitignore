# Track the Buildroot source tree so a fresh clone can build without
# separately unpacking the tarball. Buildroot's own .gitignore still filters
# generated artifacts such as output/, dl/, and transient config files.
/*
!/.gitignore
!/README.md

!/docs/
/docs/*
!/docs/*.md
!/docs/*.txt

!/buildroot-2024.02.9/
!/buildroot-2024.02.9/**

!/br2-external/
!/br2-external/**

!/app/
!/app/**
